@model List<PatientFeedbackDto>

@{
    Layout = null;

    // حساب الإحصائيات العامة ديناميكياً
    var totalFeedbacks = Model.Count;
    var positiveCount = Model.Count(x => x.feedbackSentiment == FeedbackSentiment.Positive);
    var negativeCount = Model.Count(x => x.feedbackSentiment == FeedbackSentiment.Negative);

    var positivePercentage = totalFeedbacks > 0 ? (positiveCount * 100 / totalFeedbacks) : 0;
    var negativePercentage = totalFeedbacks > 0 ? (negativeCount * 100 / totalFeedbacks) : 0;

    // جلب تصنيفات الشكاوى للفلترة ديناميكياً من الـ Enum الخاص بك
    var classifications = Enum.GetValues(typeof(ComplaintClassification)).Cast<ComplaintClassification>();
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>مركز تحليل آراء المرضى | صيدلية الرحمة</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --accent-blue: #38bdf8;
            --pos-green: #10b981;
            --neg-red: #ef4444;
            --warning-orange: #f97316;
            --border: rgba(255, 255, 255, 0.1);
        }

        body {
            background: radial-gradient(circle at top left, #1e293b, #0f172a);
            color: #f8fafc;
            font-family: 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            padding: 40px 0;
        }

        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 25px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
        }

        .main-header h1 {
            background: linear-gradient(90deg, #fff, var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        /* كروت الإحصائيات العلوية */
        .stat-box {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .stat-box.positive {
                border-bottom: 4px solid var(--pos-green);
            }

            .stat-box.negative {
                border-bottom: 4px solid var(--neg-red);
            }

            .stat-box.total {
                border-bottom: 4px solid var(--accent-blue);
            }

        /* كروت التعليقات */
        .feedback-card {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 15px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid var(--border);
        }

            /* تمييز الإيجابي عن السلبي حركياً وبصرياً */
            .feedback-card.is-positive {
                border-right: 5px solid var(--pos-green);
            }

                .feedback-card.is-positive:hover {
                    background: rgba(16, 185, 129, 0.05);
                    transform: scale(1.01);
                }

            .feedback-card.is-negative {
                border-right: 5px solid var(--neg-red);
            }

                .feedback-card.is-negative:hover {
                    background: rgba(239, 68, 68, 0.05);
                    transform: scale(1.01);
                }

        /* بادجات الحالة */
        .sentiment-badge {
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
        }

            .sentiment-badge.pos {
                background: rgba(16, 185, 129, 0.15);
                color: var(--pos-green);
                border: 1px solid rgba(16, 185, 129, 0.3);
            }

            .sentiment-badge.neg {
                background: rgba(239, 68, 68, 0.15);
                color: var(--neg-red);
                border: 1px solid rgba(239, 68, 68, 0.3);
            }

        .problem-badge {
            background: rgba(249, 115, 22, 0.15);
            color: var(--warning-orange);
            border: 1px solid rgba(249, 115, 22, 0.3);
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .patient-info {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 15px;
            padding-top: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 0.85rem;
            color: #94a3b8;
        }

            .patient-info i {
                color: var(--accent-blue);
            }

        /* أدوات التحكم والفلترة */
        .form-control, .form-select {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border);
            color: #fff;
            border-radius: 12px;
            padding: 10px 15px;
        }

            .form-control:focus, .form-select:focus {
                background: rgba(15, 23, 42, 0.8);
                border-color: var(--accent-blue);
                box-shadow: 0 0 0 0.25rem rgba(56, 189, 248, 0.25);
                color: #fff;
            }
    </style>
</head>
<body>

    <div class="container">
        <!-- الهيدر الرئيسي -->
        <div class="row mb-4 align-items-center">
            <div class="col-md-10">
                <div class="main-header">
                    <h1 class="display-6">نظام تحليل آراء وتقييمات المرضى</h1>
                    <p class="lead text-secondary mb-0">لوحة ذكية لعرض وتحليل الانطباعات العامة ورصد المشكلات الحالية.</p>
                </div>
            </div>
        </div>

        <!-- عدادات الإحصائيات السريعة -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-box total">
                    <span class="text-secondary small d-block mb-1">إجمالي التقييمات الواردة</span>
                    <h2 class="fw-bold mb-0 text-white">@totalFeedbacks</h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-box positive">
                    <span class="text-secondary small d-block mb-1">التقييمات الإيجابية (الرضا)</span>
                    <h2 class="fw-bold mb-0 text-success">@positiveCount <span class="fs-6 text-muted">(@positivePercentage%)</span></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-box negative">
                    <span class="text-secondary small d-block mb-1">الشكاوى والبلاغات السلبية</span>
                    <h2 class="fw-bold mb-0 text-danger">@negativeCount <span class="fs-6 text-muted">(@negativePercentage%)</span></h2>
                </div>
            </div>
        </div>

        <!-- أدوات البحث والفلترة الذكية -->
        <div class="glass-card mb-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-secondary">البحث عن مريض</label>
                    <input type="text" id="searchInput" class="form-control" placeholder="اكتب اسم المريض أو الرقم...">
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-secondary">تحليل الانطباع (Sentiment)</label>
                    <select id="sentimentFilter" class="form-select">
                        <option value="ALL">عرض الكل (إيجابي وسلبي)</option>
                        <option value="Positive">البلاغات الإيجابية فقط 👍</option>
                        <option value="Negative">الشكاوى السلبية فقط 👎</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-secondary">تصنيف المشكلة (للشكاوى السلبية)</label>
                    <select id="problemFilter" class="form-select">
                        <option value="ALL">كل أنواع المشاكل</option>
                        @foreach (var c in classifications)
                        {
                            <option value="@c.ToString()">@c.ToString()</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- قائمة التقييمات والتعليقات -->
        <div id="feedbackContainer">
            @if (!Model.Any())
            {
                <div class="glass-card text-center py-5">
                    <i class="fas fa-folder-open text-secondary display-3 mb-3"></i>
                    <h5>لا توجد أي بيانات تقييمات مسجلة حالياً!</h5>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    var isPos = item.feedbackSentiment == FeedbackSentiment.Positive;

                    <div class="feedback-card @(isPos ? "is-positive" : "is-negative")"
                         data-name="@item.PatientName"
                         data-phone="@item.PhoneNumber"
                         data-sentiment="@item.feedbackSentiment.ToString()"
                         data-problem="@(isPos ? "NONE" : item.ComplaintClassification.ToString())">

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h6 class="fw-bold text-white mb-2">@item.PatientName</h6>

                                <!-- بادج نوع الانطباع (إيجابي / سلبي) -->
                                @if (isPos)
                                {
                                    <span class="sentiment-badge pos">
                                        <i class="fas fa-smile me-1"></i> إيجابي / رأي داعم
                                    </span>
                                }
                                else
                                {
                                    <span class="sentiment-badge neg me-2">
                                        <i class="fas fa-frown me-1"></i> سلبي / شكوى
                                    </span>

                                    <!-- بادج قسم المشكلة المستخرج برمجياً ومطابق للموديل والـ DTO -->
                                    <span class="problem-badge">
                                        <i class="fas fa-exclamation-circle me-1"></i> القسم: @item.ComplaintClassification.ToString()
                                    </span>
                                }
                            </div>

                            <small class="text-muted"><i class="far fa-clock me-1"></i> مراجعة فورية</small>
                        </div>

                        <!-- نص التعليق أو الملاحظة -->
                        <p class="text-light opacity-75 small mb-3">
                            @(string.IsNullOrEmpty(item.Notes) ? "لا توجد تفاصيل نصية مكتوبة." : item.Notes)
                        </p>

                        <!-- بيانات التواصل الخاصة بالمريض -->
                        <div class="patient-info">
                            <span><i class="fas fa-phone-alt me-1"></i> @item.PhoneNumber</span>
                            @if (!string.IsNullOrEmpty(item.Address))
                            {
                                <span><i class="fas fa-map-marker-alt me-1"></i> @item.Address</span>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <script>
        // تفعيل محرك الفلترة والبحث اللحظي
        document.getElementById('searchInput').addEventListener('input', runFilters);
        document.getElementById('sentimentFilter').addEventListener('change', runFilters);
        document.getElementById('problemFilter').addEventListener('change', runFilters);

        function runFilters() {
            const searchVal = document.getElementById('searchInput').value.toLowerCase().trim();
            const sentimentVal = document.getElementById('sentimentFilter').value;
            const problemVal = document.getElementById('problemFilter').value;

            const cards = document.querySelectorAll('.feedback-card');

            cards.forEach(card => {
                const name = card.getAttribute('data-name').toLowerCase();
                const phone = card.getAttribute('data-phone');
                const sentiment = card.getAttribute('data-sentiment');
                const problem = card.getAttribute('data-problem');

                // شروط المطابقة للفلترة اللحظية
                const matchesSearch = name.includes(searchVal) || phone.includes(searchVal);
                const matchesSentiment = (sentimentVal === 'ALL') || (sentiment === sentimentVal);
                const matchesProblem = (problemVal === 'ALL') || (problem === problemVal);

                // إظهار أو إخفاء الكارت بناءً على الفلترة المشتركة
                if (matchesSearch && matchesSentiment && matchesProblem) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>