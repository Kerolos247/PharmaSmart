@model List<PatientFeedbackDto>

@{
    Layout = null;
    var posCount = Model.Count(x => x.feedbackSentiment == FeedbackSentiment.Positive);
    var negCount = Model.Count(x => x.feedbackSentiment == FeedbackSentiment.Negative);
    var total = posCount + negCount;
    // حساب النسبة المئوية للإيجابية
    var posPercentage = total > 0 ? (posCount * 100 / total) : 0;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تحليلات المشاعر | صيدلية الرحمة</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --accent-blue: #38bdf8;
            --pos-green: #10b981;
            --neg-red: #ef4444;
            --border: rgba(255, 255, 255, 0.1);
        }

        body {
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
            color: #f8fafc;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            min-height: 100vh;
            padding: 40px 0;
        }

        /* تأثير الزجاج للكروت */
        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 25px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
        }

        .main-header h1 {
            background: linear-gradient(90deg, #fff, var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            letter-spacing: -1px;
        }

        /* إحصائيات سريعة */
        .stat-badge {
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 600;
            background: rgba(56, 189, 248, 0.1);
            color: var(--accent-blue);
            border: 1px solid rgba(56, 189, 248, 0.2);
        }

        /* تصميم الكارت الخاص بالرأي */
        .feedback-item {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border-right: 4px solid transparent;
        }

            .feedback-item:hover {
                background: rgba(255, 255, 255, 0.07);
                transform: translateX(-5px);
            }

            .feedback-item.positive {
                border-right-color: var(--pos-green);
            }

            .feedback-item.negative {
                border-right-color: var(--neg-red);
            }

        .patient-meta {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 15px;
            padding-top: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 0.85rem;
            color: #94a3b8;
        }

            .patient-meta i {
                color: var(--accent-blue);
            }

        /* الشارت المحسن */
        .chart-container {
            position: relative;
            height: 320px;
            width: 100%;
        }

        .center-score {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -40%);
            text-align: center;
        }

            .center-score span {
                display: block;
                font-size: 0.9rem;
                color: #94a3b8;
                text-transform: uppercase;
            }

            .center-score h2 {
                font-size: 3rem;
                font-weight: 800;
                margin: 0;
                color: #fff;
            }

        /* العناوين الجانبية */
        .column-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
            font-weight: 700;
            font-size: 1.25rem;
        }

        .custom-scroll {
            max-height: 800px;
            overflow-y: auto;
            padding-left: 10px;
        }

            /* تخصيص السكرول بار */
            .custom-scroll::-webkit-scrollbar {
                width: 6px;
            }

            .custom-scroll::-webkit-scrollbar-track {
                background: transparent;
            }

            .custom-scroll::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.1);
                border-radius: 10px;
            }

    </style>
</head>
<body>

    <div class="container">
        <div class="row mb-5 align-items-center">
            <div class="col-md-8">
                <div class="main-header">
                    <h1 class="display-4">لوحة تحليل تجربة المريض</h1>
                    <p class="lead text-secondary">نحلل @total مراجعة لتحسين جودة الخدمة في <span class="text-white fw-bold">صيدلية الرحمة</span></p>
                </div>
            </div>
            <div class="col-md-4 text-md-start">
                <span class="stat-badge">
                    <i class="fas fa-calendar-alt me-2"></i> تحديث مباشر: @DateTime.Now.ToString("HH:mm")
                </span>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="glass-card sticky-top" style="top: 20px;">
                    <h5 class="mb-4 fw-bold">مؤشر الرضا العام</h5>
                    <div class="chart-container">
                        <canvas id="sentimentChart"></canvas>
                        <div class="center-score">
                            <span>الإيجابية</span>
                            <h2>@posPercentage%</h2>
                        </div>
                    </div>

                    <div class="mt-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-smile text-success me-2"></i> مراجعات جيدة</span>
                            <span class="fw-bold">@posCount</span>
                        </div>
                        <div class="progress mb-4" style="height: 6px; background: rgba(255,255,255,0.1);">
                            <div class="progress-bar bg-success" style="width: @posPercentage%"></div>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-frown text-danger me-2"></i> شكاوى</span>
                            <span class="fw-bold">@negCount</span>
                        </div>
                        <div class="progress" style="height: 6px; background: rgba(255,255,255,0.1);">
                            @{
                                var negPer = 100 - posPercentage;
                            }
                            <div class="progress-bar bg-danger" style="width: @negPer%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="row">
                    <div class="col-md-6 custom-scroll">
                        <div class="column-title text-success">
                            <i class="fas fa-quote-right"></i>
                            الآراء الإيجابية
                        </div>

                        @foreach (var item in Model.Where(x => x.feedbackSentiment == FeedbackSentiment.Positive))
                        {
                            <div class="feedback-item positive">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0 text-white">@item.PatientName</h6>
                                    <i class="fas fa-check-circle text-success small"></i>
                                </div>
                                <p class="small text-light opacity-75 mb-0">@item.Notes</p>
                                <div class="patient-meta">
                                    <span><i class="fas fa-phone-alt"></i> @item.PhoneNumber</span>
                                    <span><i class="fas fa-map-marker-alt"></i> @item.Address</span>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="col-md-6 custom-scroll">
                        <div class="column-title text-danger">
                            <i class="fas fa-exclamation-circle"></i>
                            تحتاج لمراجعة
                        </div>

                        @foreach (var item in Model.Where(x => x.feedbackSentiment == FeedbackSentiment.Negative))
                        {
                            <div class="feedback-item negative">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0 text-white">@item.PatientName</h6>
                                    <i class="fas fa-info-circle text-danger small"></i>
                                </div>
                                <p class="small text-light opacity-75 mb-0">@item.Notes</p>
                                <div class="patient-meta">
                                    <span><i class="fas fa-phone-alt"></i> @item.PhoneNumber</span>
                                    <span><i class="fas fa-map-marker-alt"></i> @item.Address</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const ctx = document.getElementById('sentimentChart').getContext('2d');

        // تدرج لوني للشارت
        const posGradient = ctx.createLinearGradient(0, 0, 0, 400);
        posGradient.addColorStop(0, '#10b981');
        posGradient.addColorStop(1, '#059669');

        const negGradient = ctx.createLinearGradient(0, 0, 0, 400);
        negGradient.addColorStop(0, '#ef4444');
        negGradient.addColorStop(1, '#991b1b');

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['إيجابي', 'سلبي'],
                datasets: [{
                    data: [@posCount, @negCount],
                    backgroundColor: [posGradient, negGradient],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                cutout: '85%',
                plugins: {
                    legend: { display: false }
                },
                animation: {
                    animateScale: true,
                    animateRotate: true
                }
            }
        });
    </script>
</body>
</html>